@model IEnumerable<CommunityLibrary.Models.Loan>
@{
    ViewData["Title"] = "Loans";
}

<h1>Loans</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Create New Loan</a>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Book</th>
            <th>Member</th>
            <th>Loan Date</th>
            <th>Due Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Book.Title</td>
            <td>@item.Member.FullName</td>
            <td>@item.LoanDate.ToShortDateString()</td>
            <td>@item.DueDate.ToShortDateString()</td>
            <td>
                @if (item.ReturnedDate != null)
                {
                    <span class="badge bg-secondary">Returned (@item.ReturnedDate.Value.ToShortDateString())</span>
                }
                else if (item.DueDate < DateTime.Today)
                {
                    <span class="badge bg-danger">Overdue</span>
                }
                else
                {
                    <span class="badge bg-success">Active</span>
                }
            </td>
            <td class="text-end">
                @if (item.ReturnedDate == null)
                {
                    <a asp-action="Return" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Mark Returned</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>

