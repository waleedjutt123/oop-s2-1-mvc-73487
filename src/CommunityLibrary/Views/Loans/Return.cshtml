@model CommunityLibrary.Models.Loan
@{
    ViewData["Title"] = "Return Loan";
}

<h1>Mark Loan as Returned</h1>

<div class="mt-3">
    <dl class="row">
        <dt class="col-sm-2">Book</dt>
        <dd class="col-sm-10">@Model.Book.Title</dd>

        <dt class="col-sm-2">Member</dt>
        <dd class="col-sm-10">@Model.Member.FullName</dd>

        <dt class="col-sm-2">Loan Date</dt>
        <dd class="col-sm-10">@Model.LoanDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Due Date</dt>
        <dd class="col-sm-10">@Model.DueDate.ToShortDateString()</dd>
    </dl>
</div>

<form asp-action="Return" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-primary">Mark Returned</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

