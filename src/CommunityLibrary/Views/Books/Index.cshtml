@model CommunityLibrary.Models.BookIndexViewModel
@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>

<form asp-action="Index" method="get" class="row g-3 mb-3">
    <div class="col-md-4">
        <label class="form-label">Search (Title or Author)</label>
        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Category</label>
        <select name="category" class="form-select">
            <option value="">All</option>
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat" selected="@(cat == Model.Category ? "selected" : null)">@cat</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Availability</label>
        <select name="availability" class="form-select">
            <option value="All" selected="@(string.IsNullOrEmpty(Model.Availability) || Model.Availability == "All" ? "selected" : null)">All</option>
            <option value="Available" selected="@(Model.Availability == "Available" ? "selected" : null)">Available</option>
            <option value="OnLoan" selected="@(Model.Availability == "OnLoan" ? "selected" : null)">On loan</option>
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Create New Book</a>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Books.First().Title)</th>
            <th>@Html.DisplayNameFor(m => m.Books.First().Author)</th>
            <th>@Html.DisplayNameFor(m => m.Books.First().Isbn)</th>
            <th>@Html.DisplayNameFor(m => m.Books.First().Category)</th>
            <th>@Html.DisplayNameFor(m => m.Books.First().IsAvailable)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Books)
{
        <tr>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.Isbn</td>
            <td>@item.Category</td>
            <td>
                @if (item.IsAvailable)
                {
                    <span class="badge bg-success">Available</span>
                }
                else
                {
                    <span class="badge bg-danger">On loan</span>
                }
            </td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

